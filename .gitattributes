# Shell scripts must use LF line endings (Linux)
*.sh    text eol=lf

# Web frontend — keep LF as most tooling expects
*.vue   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Java properties — LF
*.properties  text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.xml         text eol=lf
*.java        text eol=lf

# Python — LF
*.py    text eol=lf
*.md    text eol=lf
